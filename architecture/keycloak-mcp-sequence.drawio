        <mxCell id="e17" value="Return `web-app-proxy` client credentials + redirect URIs" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1215" y="890" as="sourcePoint" />
            <mxPoint x="655" y="890" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e18" value="GET `/protocol/openid-connect/auth`&lt;br&gt;client_id, redirect_uri, scope, code_challenge" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
