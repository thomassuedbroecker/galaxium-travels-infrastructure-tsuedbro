            <mxPoint x="935" y="1270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e26" value="Forward authenticated `initialize` request to `/mcp`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="935" y="1310" as="sourcePoint" />
            <mxPoint x="1215" y="1310" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e27" value="GET `/protocol/openid-connect/certs` (JWKS, if cache miss)" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1215" y="1350" as="sourcePoint" />
            <mxPoint x="1505" y="1350" as="targetPoint" />
          </mxGeometry>
