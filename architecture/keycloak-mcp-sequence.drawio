        <mxCell id="e30" value="Connected state + MCP session id" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="935" y="1470" as="sourcePoint" />
            <mxPoint x="655" y="1470" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e31" value="Run `tools/list` or `tools/call`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
