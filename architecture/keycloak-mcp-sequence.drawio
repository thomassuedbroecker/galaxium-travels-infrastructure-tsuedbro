        <mxCell id="e19" value="Log in with `demo-user` and approve browser flow" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="125" y="970" as="sourcePoint" />
            <mxPoint x="1505" y="970" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e20" value="Redirect back with authorization code" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1505" y="1010" as="sourcePoint" />
            <mxPoint x="655" y="1010" as="targetPoint" />
