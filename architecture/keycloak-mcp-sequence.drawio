            <mxPoint x="370" y="430" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e8" value="`docker exec web_app ...`&lt;br&gt;POST `/realms/galaxium/protocol/openid-connect/token`&lt;br&gt;grant_type=password, client_id=`web-app-proxy`, user=`demo-user`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="470" as="sourcePoint" />
            <mxPoint x="1505" y="470" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e9" value="Return traveler access token&lt;br&gt;issuer=`keycloak:8080`, audience=`booking-api`" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1505" y="520" as="sourcePoint" />
            <mxPoint x="370" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e10" value="Print browser URL, helper config file, and `Custom Header JSON`" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
