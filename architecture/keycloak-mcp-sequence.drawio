        <mxCell id="e12" value="GET `/.well-known/oauth-protected-resource`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="655" y="690" as="sourcePoint" />
