        <mxCell id="e21" value="POST `/protocol/openid-connect/token`&lt;br&gt;grant_type=authorization_code" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
