        <mxCell id="phase1" value="Phase A: local startup preflight and helper token generation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="130" width="1580" height="32" as="geometry" />
        </mxCell>
        <mxCell id="phase2" value="Phase B: Inspector OAuth bootstrap and dynamic client registration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="600" width="1580" height="32" as="geometry" />
        </mxCell>
        <mxCell id="phase3" value="Phase C: final authenticated MCP session via Custom Headers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="1130" width="1580" height="32" as="geometry" />
        </mxCell>
        <mxCell id="note_top" value="Important local-compose nuance:&lt;br&gt;- Discovery metadata is exposed with host-reachable Keycloak URLs (`localhost:8080`).&lt;br&gt;- Final JWT validation inside the MCP container still uses the internal issuer (`keycloak:8080`)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1065" y="170" width="545" height="84" as="geometry" />
        </mxCell>
        <mxCell id="note_proxy" value="`Via Proxy` mode sends:&lt;br&gt;- `X-MCP-Proxy-Auth` to the proxy&lt;br&gt;- `Authorization: Bearer ...` to the MCP server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="780" y="1280" width="315" height="84" as="geometry" />
        </mxCell>
        <mxCell id="note_bottom" value="Resulting rule for the local MCP path:&lt;br&gt;1. Complete the Inspector OAuth/bootstrap flow so the client is registered in Keycloak.&lt;br&gt;2. For the final MCP session, use the bearer token minted inside compose (`docker exec web_app ... http://keycloak:8080/...`).&lt;br&gt;3. The MCP server validates RS256 signature, issuer=`http://keycloak:8080/realms/galaxium`, and audience=`booking-api` before allowing `initialize`, `tools/list`, and `tools/call`." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="30" y="1765" width="1580" height="110" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="Run `bash local-container/start-mcp-inspector-ui.sh`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="125" y="190" as="sourcePoint" />
            <mxPoint x="370" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e2" value="GET `/.well-known/oauth-protected-resource`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="230" as="sourcePoint" />
            <mxPoint x="1215" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e3" value="Return `resource` + `authorization_servers`" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1215" y="270" as="sourcePoint" />
            <mxPoint x="370" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e4" value="GET `/.well-known/oauth-authorization-server`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="310" as="sourcePoint" />
            <mxPoint x="1215" y="310" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e5" value="Return `issuer`, `authorization_endpoint`, `token_endpoint`, `jwks_uri`, `registration_endpoint`" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1215" y="350" as="sourcePoint" />
            <mxPoint x="370" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e6" value="POST `/oauth/register` (preflight)&lt;br&gt;redirect_uri=`http://localhost:6274/oauth/callback`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="390" as="sourcePoint" />
            <mxPoint x="1215" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e7" value="201 Created&lt;br&gt;`client_id`, `client_secret`, `redirect_uris`, grant types" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
