        <mxCell id="e15" value="Return issuer=`http://localhost:8080/realms/galaxium` + register endpoint" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1215" y="810" as="sourcePoint" />
            <mxPoint x="655" y="810" as="targetPoint" />
