        <mxCell id="e22" value="Return Inspector bootstrap access token + refresh token" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1505" y="1090" as="sourcePoint" />
            <mxPoint x="655" y="1090" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e23" value="Set `Streamable HTTP`, `http://localhost:8084/mcp`, `Via Proxy`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="125" y="1180" as="sourcePoint" />
            <mxPoint x="655" y="1180" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e24" value="Paste `Authorization: Bearer &lt;token from script&gt;` into `Custom Headers`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="125" y="1220" as="sourcePoint" />
            <mxPoint x="655" y="1220" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e25" value="POST `/mcp?url=...&amp;transportType=streamable-http`&lt;br&gt;JSON-RPC `initialize` + `Authorization` + `X-MCP-Proxy-Auth`" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
