        <mxCell id="e28" value="Return JWKS" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1505" y="1390" as="sourcePoint" />
            <mxPoint x="1215" y="1390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e29" value="Validate JWT signature + issuer + audience&lt;br&gt;create FastMCP access context&lt;br&gt;return `initialize` result" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1215" y="1430" as="sourcePoint" />
            <mxPoint x="935" y="1430" as="targetPoint" />
          </mxGeometry>
