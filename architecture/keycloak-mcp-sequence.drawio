        <mxCell id="e34" value="Validate token (JWKS cached), execute MCP method/tool, return JSON-RPC response" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeWidth=2;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
