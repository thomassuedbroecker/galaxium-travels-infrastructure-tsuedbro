# Simple host-based local defaults.
# Compose overrides these values automatically.
export BACKEND_URL=http://localhost:8082
export OAUTH2_ENABLED=false
export FRONTEND_AUTH_REQUIRED=false
# Set these when OAUTH2_ENABLED=true.
# export OIDC_TOKEN_URL=http://localhost:8080/realms/galaxium/protocol/openid-connect/token
# export OIDC_CLIENT_ID=web-app-proxy
# export OIDC_CLIENT_SECRET=web-app-proxy-secret
# export OIDC_SCOPE=openid profile email
# Set this when FRONTEND_AUTH_REQUIRED=true.
# export FLASK_SECRET_KEY=replace-with-a-long-random-secret
