export APP_NAME="galaxium-booking-web-app"
export PROJECT_NAME="galaxium-travel-services-tsuedbro"
export GIT_REPO="https://github.com/thomassuedbroecker/galaxium-travels-infrastructure.git"
export CONTEXT_DIR="galaxium-booking-web-app"
export RESOURCE_GROUP="tsuedbro"
export PORT="8083"
# Docker Compose configuration
export BACKEND_URL=http://booking_system:8082
# IMPORTANT:
# - OAUTH2_ENABLED=false => no Keycloak token is requested by this web app.
# - OAUTH2_ENABLED=true  => Keycloak token is required for web-app -> backend calls.
# - FRONTEND_AUTH_REQUIRED defaults to OAUTH2_ENABLED when not set.
# - FRONTEND_AUTH_REQUIRED=true => traveler login is mandatory in the frontend.
export OAUTH2_ENABLED=false
export FRONTEND_AUTH_REQUIRED=false
# Set these when OAUTH2_ENABLED=true
# export OIDC_TOKEN_URL=http://keycloak:8080/realms/galaxium/protocol/openid-connect/token
# export OIDC_CLIENT_ID=web-app-proxy
# export OIDC_CLIENT_SECRET=web-app-proxy-secret
# Optional scopes for token requests
# export OIDC_SCOPE=openid profile email
# Set this when FRONTEND_AUTH_REQUIRED=true
# export FLASK_SECRET_KEY=replace-with-a-long-random-secret
# Code Engine  configuration
# export BACKEND_URL=https://galaxium-booking-system.XXXX.us-south.codeengine.appdomain.cloud 
# export OIDC_TOKEN_URL=https://<your-keycloak-url>/realms/galaxium/protocol/openid-connect/token
# export OIDC_CLIENT_ID=web-app-proxy
# export OIDC_CLIENT_SECRET=<your-web-app-proxy-client-secret>

export API_KEY=YOUR_API_KEY
