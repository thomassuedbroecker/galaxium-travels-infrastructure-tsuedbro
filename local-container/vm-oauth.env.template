# Copy this file to vm-oauth.env before starting the VM/external OAuth compose variant.
#
# Topology this file targets:
# - this compose stack runs on the host machine
# - a second compose stack may run inside a VM on the same machine
# - the VM-side containers reach this stack over the host machine LAN IP / DNS name
#
# These URLs must therefore point to the host-machine address that is reachable from the VM.
# Do not use localhost here for the split host+VM setup.

KEYCLOAK_PUBLIC_BASE_URL=http://your-host-lan-ip-or-dns:8080
MCP_PUBLIC_BASE_URL=http://your-host-lan-ip-or-dns:8084

# Only relevant when another compose project uses the same Docker daemon.
# A compose project running inside a separate VM cannot join this network.
GALAXIUM_SHARED_NETWORK=galaxium-vm-oauth

# Optional: extend this when you use MCP Inspector from somewhere other than localhost:6274.
OIDC_INSPECTOR_REDIRECT_URIS=http://localhost:6274/oauth/callback,http://localhost:6274/oauth/callback/debug,http://127.0.0.1:6274/oauth/callback,http://127.0.0.1:6274/oauth/callback/debug
