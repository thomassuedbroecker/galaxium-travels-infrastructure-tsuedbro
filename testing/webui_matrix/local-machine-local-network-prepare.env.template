# WebUI auth matrix template for the LAN-prepare path.
# Replace the host below with the IP or DNS name that a VM can reach.
# Usage:
#   cp testing/webui_matrix/local-machine-local-network-prepare.env.template testing/webui_matrix/local-machine-local-network-prepare.env
#   bash testing/automation/run-webui-auth-matrix.sh --env-file testing/webui_matrix/local-machine-local-network-prepare.env

WEBUI_TEST_PUBLIC_HOST=192.168.1.50
WEBUI_TEST_RUN_DOCKER=1
WEBUI_TEST_SKIP_BUILD=1
WEBUI_TEST_KEEP_STACK=0
WEBUI_TEST_ENVIRONMENT=local_machine_local_network_prepare
WEBUI_TEST_BACKEND_MODE=mcp
WEBUI_TEST_OAUTH_MODE=backend_and_ui_oauth
